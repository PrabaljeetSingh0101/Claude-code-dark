    "button.background": "#D77757",
    "button.foreground": "#000000",
    "button.hoverBackground": "#EB9F7F",

    "list.activeSelectionBackground": "#264F78",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.hoverBackground": "#373737",
    "list.focusBackground": "#264F7880",
    "list.highlightForeground": "#D77757",

    "terminal.background": "#1A1A19",
    "terminal.foreground": "#FFFFFF",
    "terminalCursor.foreground": "#D77757",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#DC2626",
    "terminal.ansiGreen": "#16A34A",
    "terminal.ansiYellow": "#CA8A04",
    "terminal.ansiBlue": "#6A9BCC",
    "terminal.ansiMagenta": "#827DBD",
    "terminal.ansiCyan": "#0891B2",
    "terminal.ansiWhite": "#c3c2b7",
    "terminal.ansiBrightBlack": "#505050",
    "terminal.ansiBrightRed": "#FF6B80",
    "terminal.ansiBrightGreen": "#4EBA65",
    "terminal.ansiBrightYellow": "#FFC107",
    "terminal.ansiBrightBlue": "#B1C3FF",
    "terminal.ansiBrightMagenta": "#AF87FF",
    "terminal.ansiBrightCyan": "#00CCCC",
    "terminal.ansiBrightWhite": "#c3c2b7"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": { "foreground": "#6A9BCC" },
    "interface": { "foreground": "#6A9BCC" },
    "type": { "foreground": "#6A9BCC" },
    "enum": { "foreground": "#6A9BCC" },
    "function": { "foreground": "#FBBC04" },
    "method": { "foreground": "#FBBC04" },
    "macro": { "foreground": "#827DBD" },
    "variable": { "foreground": "#FFFFFF" },
    "variable.readonly": { "foreground": "#827DBD" },
    "property": { "foreground": "#FFFFFF" },
    "parameter": { "foreground": "#FFFFFF" },
    "keyword": { "foreground": "#D77757" },
    "string": { "foreground": "#4EBA65" },
    "number": { "foreground": "#827DBD" },
    "boolean": { "foreground": "#827DBD" },
    "comment": { "foreground": "#999999" }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#999999" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.modifier", "storage.type", "keyword.control"],
      "settings": { "foreground": "#D77757" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#4EBA65" }
    },
    {
      "name": "Numbers & Booleans",
      "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#827DBD" }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#FBBC04" }
    },
    {
      "name": "Types & Classes",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#6A9BCC" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#D77757" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#999999" }
    },
    {
      "name": "Object Properties",
      "scope": ["meta.object-literal.key", "variable.other.property"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "HTML/XML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#D77757" }
    },
    {
      "name": "HTML/XML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FBBC04" }
    },
    {
      "name": "CSS Selectors",
      "scope": ["entity.other.attribute-name.class", "entity.other.attribute-name.id"],
      "settings": { "foreground": "#FBBC04" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#6A9BCC" }
    },
    {
      "name": "Markdown Headings",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#D77757" }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#6A9BCC" }
    }
  ]
}
