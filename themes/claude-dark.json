    "editor.findMatchHighlightBackground": "#FBBC0420",
    "editor.lineHighlightBackground": "#37373780",
    "editor.lineHighlightBorder": "#00000000",

    "editorWhitespace.foreground": "#505050",
    "editorIndentGuide.background1": "#505050",
    "editorIndentGuide.activeBackground1": "#999999",
    "editorBracketMatch.background": "#D7775729",
    "editorBracketMatch.border": "#D77757",

    "editorBracketHighlight.foreground1": "#D77757",
    "editorBracketHighlight.foreground2": "#FBBC04",
    "editorBracketHighlight.foreground3": "#6A9BCC",
    "editorBracketHighlight.foreground4": "#4EBA65",
    "editorBracketHighlight.foreground5": "#827DBD",
    "editorBracketHighlight.foreground6": "#FF6B80",

    "editorGutter.background": "#1A1A19",
    "editorGutter.addedBackground": "#4EBA65",
    "editorGutter.modifiedBackground": "#FBBC04",
    "editorGutter.deletedBackground": "#FF6B80",

    "editorWidget.background": "#1F1F1E",
    "editorWidget.foreground": "#FFFFFF",
    "editorWidget.border": "#505050",
    "editorSuggestWidget.background": "#1F1F1E",
    "editorSuggestWidget.border": "#505050",
    "editorSuggestWidget.highlightForeground": "#D77757",
    "editorSuggestWidget.selectedBackground": "#264F78",

    "editorError.foreground": "#FF6B80",
    "editorWarning.foreground": "#FFC107",
