    "editorGroup.border": "#505050",

    "tab.activeBackground": "#1A1A19",
    "tab.activeForeground": "#FFFFFF",
    "tab.activeBorder": "#D77757",
    "tab.activeBorderTop": "#D77757",
    "tab.inactiveBackground": "#1F1F1E",
    "tab.inactiveForeground": "#999999",
    "tab.border": "#505050",

    "editor.background": "#1A1A19",
    "editor.foreground": "#FFFFFF",
    "editorLineNumber.foreground": "#505050",
    "editorLineNumber.activeForeground": "#999999",
    "editorCursor.foreground": "#D77757",
    "editor.selectionBackground": "#264F78",
    "editor.inactiveSelectionBackground": "#264F7880",
    "editor.selectionHighlightBackground": "#264F7880",
    "editor.wordHighlightBackground": "#264F7880",
    "editor.wordHighlightStrongBackground": "#264F78",
