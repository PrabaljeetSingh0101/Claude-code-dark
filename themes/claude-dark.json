    "diffEditor.insertedTextBackground": "#225C2B40",
    "diffEditor.insertedLineBackground": "#225C2B20",
    "diffEditor.removedTextBackground": "#7A293640",
    "diffEditor.removedLineBackground": "#7A293620",

    "panel.background": "#1A1A19",
    "panel.border": "#505050",
